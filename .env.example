# ============================================================
#  카페24 판매관리 시스템 v2.0 — 환경변수 설정
# ============================================================

# ─── 카페24 ───
CAFE24_MALL_ID=yourmall
CAFE24_CLIENT_ID=your_cafe24_client_id
CAFE24_CLIENT_SECRET=your_cafe24_client_secret
CAFE24_REDIRECT_URI=http://localhost:3000/auth/callback
CAFE24_API_VERSION=2026-03-01

# ─── 쿠팡 Wing API ───
COUPANG_VENDOR_ID=your_vendor_id
COUPANG_ACCESS_KEY=your_coupang_access_key
COUPANG_SECRET_KEY=your_coupang_secret_key

# ─── 네이버 커머스 API ───
NAVER_COMMERCE_CLIENT_ID=your_naver_client_id
NAVER_COMMERCE_CLIENT_SECRET=your_naver_client_secret

# ─── 서버 ───
PORT=3000
TOKEN_STORE_PATH=./tokens.json
